name: GitHub
description: Adds support for managing GitHub repositories through Git-Tool.
configs:
  - platform: any
    service:
      name: gh
      website: "https://github.com/{{ .Repo.FullName }}"
      gitUrl: "git@github.com:{{ .Repo.FullName }}.git"
      pattern: "*/*"
      api:
        kind: GitHub/v3
        url: https://api.github.com
