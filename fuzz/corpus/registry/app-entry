name: VSCode
description: Launches Visual Studio Code in a project directory.
configs:
  - platform: linux
    app:
      name: code
      command: code
      args:
        - "."
  - platform: windows
    app:
      name: code
      command: cmd.exe
      args:
        - "/Q"
        - "/C"
        - "code.cmd ."
      environment:
        - "EDITOR=code"
